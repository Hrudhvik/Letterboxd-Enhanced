/* Letterboxd Enhanced */
:root { --lbe-g: #00e054; --lbe-b: #40bcf4; --lbe-bg: #14181c; --lbe-c: #1b2028; --lbe-h: #242c34; --lbe-bd: #2c3440; }

/* ── Overlay ──────────────────────────────────────────── */
.lbe-ov {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 18px 8px 8px;
  background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.6) 55%, transparent 100%);
  opacity: 1; transform: translateY(0);
  transition: opacity 0.2s, transform 0.2s;
  box-sizing: border-box; z-index: 10; pointer-events: none;
}
.lbe-ov.lbe-h { opacity: 0; transform: translateY(4px); }

/* Title */
.lbe-ot { font-size: 13px; font-weight: 600; color: #fff; line-height: 1.2; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.lbe-ot.lbe-sm { font-size: 10px; margin-bottom: 1px; }

/* Meta */
.lbe-om { font-size: 9px; color: rgba(255,255,255,0.4); margin-bottom: 5px; }

/* Ratings row — all inline */
.lbe-or { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; margin-bottom: 4px; }

/* LB score */
.lbe-lb { display: inline-flex; align-items: center; gap: 3px; background: rgba(0,224,84,0.12); border: 1px solid rgba(0,224,84,0.2); border-radius: 3px; padding: 1px 5px; }
.lbe-stars { display: flex; gap: 0; line-height: 0; }
.lbe-star { color: var(--lbe-g); }
.lbe-star-off { opacity: 0.3; }
.lbe-lbv { font-size: 11px; font-weight: 700; color: var(--lbe-g); line-height: 1; }

/* External ratings inline */
.lbe-ext { display: inline-flex; gap: 4px; margin-left: auto; }
.lbe-er { display: inline-flex; align-items: center; gap: 2px; font-size: 9px; font-weight: 600; color: rgba(255,255,255,0.8); }

/* Badges M R I */
.lbe-b { width: 14px; height: 14px; border-radius: 2px; display: inline-flex; align-items: center; justify-content: center; font-size: 7px; font-weight: 700; color: #fff; flex-shrink: 0; }
.lbe-bm { background: #2e51a2; }
.lbe-br { background: #fa320a; }
.lbe-bi { background: #f5c518; color: #000; }

/* Genres */
.lbe-og { display: flex; gap: 3px; flex-wrap: wrap; }
.lbe-gt { font-size: 8px; color: rgba(255,255,255,0.45); background: rgba(255,255,255,0.07); padding: 1px 4px; border-radius: 2px; text-decoration: none; }

/* ── Sidebar ratings ──────────────────────────────────── */
.lbe-rp { background: var(--lbe-c); border: 1px solid var(--lbe-bd); border-radius: 6px; padding: 14px; margin: 16px 0; }
.lbe-rh { font-size: 11px; font-weight: 600; letter-spacing: 1.5px; color: #678; margin-bottom: 12px; text-transform: uppercase; }
.lbe-rg { display: flex; flex-direction: column; gap: 8px; }
.lbe-rc { display: flex; align-items: center; gap: 12px; padding: 10px 12px; background: var(--lbe-bg); border: 1px solid var(--lbe-bd); border-radius: 4px; text-decoration: none; color: #9ab; border-left: 3px solid var(--a, var(--lbe-bd)); transition: all 0.15s; cursor: pointer; }
.lbe-rc:hover { background: var(--lbe-h); transform: translateX(2px); }
.lbe-ri { flex: 1; }
.lbe-rs { font-size: 16px; font-weight: 700; color: #def; line-height: 1.2; }
.lbe-rd { font-size: 10px; color: #678; margin-top: 1px; }

/* ── Meta bar ─────────────────────────────────────────── */
.lbe-mb { display: flex; flex-wrap: wrap; gap: 6px; margin: 8px 0 12px; align-items: center; }
.lbe-mt { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 3px; font-size: 12px; font-weight: 500; }
.lbe-mr { background: rgba(0,224,84,0.12); color: var(--lbe-g); border: 1px solid rgba(0,224,84,0.25); }
.lbe-mc { background: rgba(255,128,0,0.12); color: #ff8000; border: 1px solid rgba(255,128,0,0.25); }
.lbe-mg { background: rgba(64,188,244,0.08); color: var(--lbe-b); border: 1px solid rgba(64,188,244,0.2); text-decoration: none; }
.lbe-mg:hover { background: rgba(64,188,244,0.18); color: #fff; }
